{
  "name": "planet-right",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:api": "pnpm --filter api wrangler dev",
    "dev:site": "pnpm --filter site astro dev",
    "dev:ext": "pnpm --filter extension dev",
    "build": "pnpm -r --filter='!planet-right' build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint 'packages/*/src/**/*.ts' 'extension/src/**/*.ts' 'api/src/**/*.ts' 'site/src/**/*.{ts,astro}'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0"
  }
}
