---
import Admin from '@/layouts/Admin.astro'
---
<Admin title="Overview">
  <div id="content">
    <!-- Stats row -->
    <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" id="stats-row">
      {['fp: Detections', 'Estimations run', 'Affiliate clicks', 'Active products'].map((label) => (
        <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
          <p class="mb-1 text-sm text-gray-400">{label}</p>
          <p class="text-3xl font-bold text-white animate-pulse bg-gray-800 rounded h-9 w-20"></p>
        </div>
      ))}
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-xl border border-gray-800 bg-gray-900 p-6" id="tiers-card">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">Estimation tiers</h2>
        <div class="h-24 flex items-center justify-center text-sm text-gray-500">Loading…</div>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900 p-6" id="recent-card">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">Recent estimations</h2>
        <div class="h-24 flex items-center justify-center text-sm text-gray-500">Loading…</div>
      </div>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { href: '/admin/catalogue', label: 'Manage catalogue →' },
        { href: '/admin/footprints', label: 'View estimations →' },
        { href: '/admin/detections', label: 'fp: detections →' },
        { href: '/admin/affiliate', label: 'Affiliate rules →' },
      ].map(({ href, label }) => (
        <a href={href} class="rounded-xl border border-gray-800 bg-gray-900 px-5 py-4 text-sm font-medium text-green-400 hover:border-gray-700 hover:bg-gray-800">
          {label}
        </a>
      ))}
    </div>
  </div>
</Admin>

<script>
  import { API_BASE } from '@/lib/config'

  const token = sessionStorage.getItem('admin_token')
  if (!token) { window.location.href = '/admin/login'; throw 0 }

  const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }

  async function load() {
    const [detectRes, estRes] = await Promise.all([
      fetch(`${API_BASE}/v1/admin/detections?pageSize=1`, { headers }).then(r => r.json()),
      fetch(`${API_BASE}/v1/admin/estimations?pageSize=5`, { headers }).then(r => r.json()),
    ])

    // Update stats row
    const statsRow = document.getElementById('stats-row')!
    const vals = [detectRes.total ?? 0, estRes.total ?? 0, 0, 0]
    const labels = ['fp: Detections', 'Estimations run', 'Affiliate clicks', 'Active products']
    const descs = ['all time', 'all time', 'all time', 'in catalogue']
    statsRow.innerHTML = vals.map((v, i) => `
      <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
        <p class="mb-1 text-sm text-gray-400">${labels[i]}</p>
        <p class="text-3xl font-bold text-white">${v.toLocaleString()}</p>
        <p class="mt-1 text-xs text-gray-500">${descs[i]}</p>
      </div>
    `).join('')

    // Tier stats
    const tierStats: Array<{ tier: number; count: number; avg_confidence: number }> = estRes.tierStats ?? []
    const tierColors: Record<number, string> = { 1: 'bg-green-500', 2: 'bg-yellow-500', 3: 'bg-red-500' }
    document.getElementById('tiers-card')!.innerHTML = `
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">Estimation tiers</h2>
      <div class="space-y-3">
        ${tierStats.length ? tierStats.map(t => `
          <div class="flex items-center gap-3">
            <span class="w-14 rounded-full bg-yellow-900/40 px-2 py-0.5 text-center text-xs font-bold text-yellow-400">Tier ${t.tier}</span>
            <div class="flex-1">
              <div class="mb-1 flex justify-between text-xs text-gray-400">
                <span>${t.count} estimations</span>
                <span>avg conf: ${(t.avg_confidence * 100).toFixed(0)}%</span>
              </div>
              <div class="h-2 rounded-full bg-gray-800">
                <div class="h-2 rounded-full ${tierColors[t.tier] ?? 'bg-green-500'}" style="width:${Math.min(100, t.avg_confidence * 100)}%"></div>
              </div>
            </div>
          </div>
        `).join('') : '<p class="text-sm text-gray-500">No estimations yet.</p>'}
      </div>
    `

    // Recent estimations
    type Est = { domain: string; product_name: string; estimated_co2e_kg: number; tier: number }
    const recent: Est[] = estRes.data ?? []
    document.getElementById('recent-card')!.innerHTML = `
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">Recent estimations</h2>
      <div class="space-y-3">
        ${recent.length ? recent.map(e => `
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <p class="truncate text-sm text-gray-200">${e.product_name ?? 'Unknown product'}</p>
              <p class="text-xs text-gray-500">${e.domain}</p>
            </div>
            <div class="flex shrink-0 items-center gap-2">
              <span class="rounded bg-gray-800 px-1.5 py-0.5 text-xs text-gray-300">${e.estimated_co2e_kg} kg</span>
              <span class="rounded-full bg-yellow-900/40 px-1.5 py-0.5 text-xs text-yellow-400">T${e.tier}</span>
            </div>
          </div>
        `).join('') : '<p class="text-sm text-gray-500">No estimations yet.</p>'}
      </div>
    `
  }

  load().catch(err => {
    document.getElementById('content')!.insertAdjacentHTML('afterbegin', `
      <div class="mb-6 rounded-xl bg-red-900/20 border border-red-800 px-4 py-3 text-sm text-red-300">${err}</div>
    `)
  })
</script>
