---
import Admin from '@/layouts/Admin.astro'
---
<Admin title="Impact">
  <div class="mb-6 flex gap-2" id="day-filters">
    <a href="?days=7" class="rounded-lg px-3 py-1.5 text-sm font-medium bg-gray-800 text-gray-400 hover:bg-gray-700">Last 7d</a>
    <a href="?days=30" class="rounded-lg px-3 py-1.5 text-sm font-medium bg-gray-800 text-gray-400 hover:bg-gray-700">Last 30d</a>
    <a href="?days=90" class="rounded-lg px-3 py-1.5 text-sm font-medium bg-gray-800 text-gray-400 hover:bg-gray-700">Last 90d</a>
  </div>

  <div id="error-box" class="mb-4 hidden rounded-xl bg-red-900/20 border border-red-800 px-4 py-3 text-sm text-red-300"></div>

  <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" id="stats-row">
    {[0,1,2,3].map(() => <div class="rounded-xl border border-gray-800 bg-gray-900 p-5 animate-pulse h-20"></div>)}
  </div>

  <div class="mb-6 rounded-xl border border-gray-800 bg-gray-900 p-6" id="chart-card">
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">CO₂e saved per day</h2>
    <div class="h-24 flex items-center justify-center text-sm text-gray-500">Loading…</div>
  </div>

  <div class="grid gap-4 md:grid-cols-2" id="breakdown"></div>
</Admin>

<script>
  import { API_BASE } from '@/lib/config'

  const token = localStorage.getItem('admin_token')
  if (!token) { window.location.href = '/admin/login'; throw 0 }

  const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }
  const days = parseInt(new URLSearchParams(location.search).get('days') ?? '30', 10)

  document.querySelectorAll('#day-filters a').forEach(a => {
    if ((a as HTMLAnchorElement).href.includes(`days=${days}`)) {
      a.className = 'rounded-lg px-3 py-1.5 text-sm font-medium bg-green-700 text-white'
    }
  })

  async function load() {
    try {
      const res = await fetch(`${API_BASE}/v1/admin/impact?days=${days}`, { headers })
      if (!res.ok) throw new Error(`API error ${res.status}`)
      type Totals = { total_events: number; total_saving_co2e_kg: number; unique_sessions: number; avg_saving_kg: number }
      type DayStat = { date: string; events: number; saving_kg: number }
      type SourceStat = { baseline_source: string; events: number; saving_kg: number }
      type CatStat = { category_slug: string; events: number; saving_kg: number }
      const data: { totals: Totals; daily: DayStat[]; bySource: SourceStat[]; byCategory: CatStat[] } = await res.json()
      const { totals, daily, bySource, byCategory } = data

      const statDefs = [
        { label: 'CO₂e saved', value: `${totals.total_saving_co2e_kg.toFixed(1)} kg`, desc: 'from recommendations' },
        { label: 'Greener clicks', value: totals.total_events.toLocaleString(), desc: 'alternatives chosen' },
        { label: 'Avg saving / click', value: `${(totals.avg_saving_kg ?? 0).toFixed(2)} kg`, desc: 'CO₂e per event' },
        { label: 'Unique sessions', value: totals.unique_sessions.toLocaleString(), desc: 'users who clicked' },
      ]
      document.getElementById('stats-row')!.innerHTML = statDefs.map(s => `
        <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
          <p class="mb-1 text-sm text-gray-400">${s.label}</p>
          <p class="text-2xl font-bold text-green-400">${s.value}</p>
          <p class="mt-1 text-xs text-gray-500">${s.desc}</p>
        </div>
      `).join('')

      const maxKg = Math.max(...daily.map(d => d.saving_kg), 1)
      document.getElementById('chart-card')!.innerHTML = `
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">CO₂e saved per day</h2>
        <div class="flex items-end gap-1 h-24">
          ${daily.length ? daily.map(d => `
            <div class="flex-1 rounded-sm bg-green-600/70 hover:bg-green-500 transition-colors"
              style="height:${Math.max(Math.round(d.saving_kg/maxKg*100), 2)}%"
              title="${d.date}: ${d.saving_kg.toFixed(2)} kg saved"></div>
          `).join('') : '<p class="text-sm text-gray-500">No impact data yet.</p>'}
        </div>
        ${daily.length > 0 ? `<div class="mt-2 flex justify-between text-xs text-gray-600"><span>${daily[0]?.date}</span><span>${daily[daily.length-1]?.date}</span></div>` : ''}
      `

      document.getElementById('breakdown')!.innerHTML = `
        <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
          <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-400">Savings by baseline source</h2>
          ${bySource.length ? bySource.map(s => `
            <div class="flex items-center justify-between border-t border-gray-800 py-2 first:border-t-0">
              <span class="text-sm text-gray-300">${s.baseline_source}</span>
              <div class="text-right">
                <span class="text-sm font-semibold text-green-400">${s.saving_kg.toFixed(1)} kg</span>
                <p class="text-xs text-gray-500">${s.events} events</p>
              </div>
            </div>
          `).join('') : '<p class="text-sm text-gray-500">No data yet.</p>'}
        </div>
        <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
          <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-400">Savings by category</h2>
          ${byCategory.length ? byCategory.map(c => `
            <div class="flex items-center justify-between border-t border-gray-800 py-2 first:border-t-0">
              <span class="text-sm text-gray-300">${c.category_slug}</span>
              <div class="text-right">
                <span class="text-sm font-semibold text-green-400">${c.saving_kg.toFixed(1)} kg</span>
                <p class="text-xs text-gray-500">${c.events} choices</p>
              </div>
            </div>
          `).join('') : '<p class="text-sm text-gray-500">No data yet.</p>'}
        </div>
      `
    } catch (err) {
      const box = document.getElementById('error-box')!
      box.textContent = String(err)
      box.classList.remove('hidden')
    }
  }

  load()
</script>
