---
import Admin from '@/layouts/Admin.astro'
import { apiGet } from '@/lib/api'

const env = (Astro.locals as Record<string, unknown>)['runtime']?.['env']
const adminToken = Astro.cookies.get('admin_token')?.value
const headers: Record<string, string> = adminToken ? { Cookie: `admin_token=${adminToken}` } : {}

const page = parseInt(Astro.url.searchParams.get('page') ?? '1', 10)
const domain = Astro.url.searchParams.get('domain') ?? ''

interface DomainSummary { domain: string; detection_count: number; last_detected: string; versions_seen: number }
interface Detection { id: number; domain: string; product_name: string | null; co2e_kg: number | null; fp_version: string | null; detected_at: string }
interface DetectionsRes { summary: DomainSummary[]; recent: Detection[]; total: number }

let summary: DomainSummary[] = []
let recent: Detection[] = []
let total = 0
let error = ''

try {
  const qs = new URLSearchParams({ page: String(page), pageSize: '30' })
  if (domain) qs.set('domain', domain)
  const res = await apiGet<DetectionsRes>(`/v1/admin/detections?${qs}`, env, headers)
  summary = res.summary
  recent = res.recent
  total = res.total
} catch (e) {
  error = String(e)
}
---
<Admin title="fp: Detections">
  <div class="mb-6">
    <p class="text-sm text-gray-400">{total} domains have sent fp: tags</p>
  </div>

  {error && (
    <div class="mb-4 rounded-xl bg-red-900/20 border border-red-800 px-4 py-3 text-sm text-red-300">{error}</div>
  )}

  <div class="grid gap-6 lg:grid-cols-2">
    <!-- Domain summary table -->
    <div class="overflow-hidden rounded-xl border border-gray-800">
      <div class="border-b border-gray-800 bg-gray-900/60 px-4 py-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">Domains by detection volume</h2>
      </div>
      <table class="w-full text-sm bg-gray-900">
        <tbody class="divide-y divide-gray-800">
          {summary.map((d) => (
            <tr class="hover:bg-gray-800/40">
              <td class="px-4 py-3">
                <a href={`?domain=${encodeURIComponent(d.domain)}`} class="font-medium text-green-400 hover:text-green-300">
                  {d.domain}
                </a>
                <p class="text-xs text-gray-500">Last: {d.last_detected.slice(0, 10)}</p>
              </td>
              <td class="px-4 py-3 text-right">
                <span class="text-gray-200 font-semibold">{d.detection_count}</span>
                <p class="text-xs text-gray-500">{d.versions_seen} version{d.versions_seen !== 1 ? 's' : ''}</p>
              </td>
            </tr>
          ))}
          {summary.length === 0 && (
            <tr><td colspan="2" class="px-4 py-8 text-center text-sm text-gray-500">No detections yet.</td></tr>
          )}
        </tbody>
      </table>
    </div>

    <!-- Recent detections -->
    <div class="overflow-hidden rounded-xl border border-gray-800">
      <div class="border-b border-gray-800 bg-gray-900/60 px-4 py-3 flex items-center justify-between">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">
          {domain ? `Recent from ${domain}` : 'Most recent detections'}
        </h2>
        {domain && (
          <a href="/admin/detections" class="text-xs text-gray-500 hover:text-gray-300">Clear filter</a>
        )}
      </div>
      <div class="divide-y divide-gray-800 bg-gray-900">
        {recent.map((r) => (
          <div class="px-4 py-3">
            <div class="flex items-start justify-between gap-2">
              <div class="min-w-0">
                <p class="truncate text-sm text-gray-200">{r.product_name ?? 'Unknown product'}</p>
                <p class="text-xs text-gray-500">{r.domain} · {r.detected_at.slice(0, 10)}</p>
              </div>
              <div class="flex shrink-0 gap-2">
                {r.co2e_kg != null && (
                  <span class="rounded bg-green-900/30 px-1.5 py-0.5 text-xs text-green-300">{r.co2e_kg} kg</span>
                )}
                {r.fp_version && (
                  <span class="rounded bg-gray-800 px-1.5 py-0.5 text-xs text-gray-400">v{r.fp_version}</span>
                )}
              </div>
            </div>
          </div>
        ))}
        {recent.length === 0 && (
          <div class="px-4 py-8 text-center text-sm text-gray-500">No recent detections.</div>
        )}
      </div>
    </div>
  </div>
</Admin>
