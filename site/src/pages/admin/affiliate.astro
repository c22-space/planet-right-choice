---
import Admin from '@/layouts/Admin.astro'
---
<Admin title="Affiliate">
  <div class="mb-6 flex gap-1 rounded-xl bg-gray-900 p-1 w-fit">
    <a href="?tab=rules" class="rounded-lg px-4 py-2 text-sm font-medium transition-colors" id="tab-rules">ASIN Rules</a>
    <a href="?tab=stats" class="rounded-lg px-4 py-2 text-sm font-medium transition-colors" id="tab-stats">Stats</a>
  </div>

  <div id="error-box" class="mb-4 hidden rounded-xl bg-red-900/20 border border-red-800 px-4 py-3 text-sm text-red-300"></div>
  <div id="tab-content"><div class="py-16 text-center text-sm text-gray-500">Loading…</div></div>
</Admin>

<script>
  import { API_BASE } from '@/lib/config'

  const token = sessionStorage.getItem('admin_token')
  if (!token) { window.location.href = '/admin/login'; throw 0 }

  const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }
  const tab = new URLSearchParams(location.search).get('tab') ?? 'rules'

  const activeClass = 'bg-gray-700 text-white'
  const inactiveClass = 'text-gray-400 hover:text-gray-200'
  document.getElementById(`tab-${tab}`)!.className = `rounded-lg px-4 py-2 text-sm font-medium transition-colors ${activeClass}`
  document.getElementById(tab === 'rules' ? 'tab-stats' : 'tab-rules')!.className = `rounded-lg px-4 py-2 text-sm font-medium transition-colors ${inactiveClass}`

  async function load() {
    try {
      if (tab === 'rules') {
        const res = await fetch(`${API_BASE}/v1/admin/affiliate/rules?includeInactive=true`, { headers })
        if (!res.ok) throw new Error(`API error ${res.status}`)
        type Rule = { id: number; source_asin: string; target_asin: string | null; affiliate_tag: string; reason: string | null; is_active: number; priority: number }
        const { rules, total }: { rules: Rule[]; total: number } = await res.json()

        document.getElementById('tab-content')!.innerHTML = `
          <div>
            <div class="mb-4 flex items-center justify-between">
              <p class="text-sm text-gray-400">${total} rules</p>
              <a href="/admin/affiliate/new" class="rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700">+ Add rule</a>
            </div>
            <div class="overflow-hidden rounded-xl border border-gray-800">
              <table class="w-full text-sm">
                <thead class="border-b border-gray-800 bg-gray-900/60">
                  <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
                    <th class="px-4 py-3">Source ASIN</th><th class="px-4 py-3">Target ASIN</th>
                    <th class="px-4 py-3">Tag</th><th class="px-4 py-3">Priority</th>
                    <th class="px-4 py-3">Status</th><th class="px-4 py-3">Reason</th><th class="px-4 py-3"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-800 bg-gray-900">
                  ${rules.length ? rules.map(r => `
                    <tr class="hover:bg-gray-800/40">
                      <td class="px-4 py-3 font-mono text-xs text-gray-200">${r.source_asin}</td>
                      <td class="px-4 py-3 font-mono text-xs text-gray-400">${r.target_asin ?? '—'}</td>
                      <td class="px-4 py-3 text-xs text-gray-400">${r.affiliate_tag}</td>
                      <td class="px-4 py-3 text-gray-400">${r.priority}</td>
                      <td class="px-4 py-3"><span class="rounded-full px-2 py-0.5 text-xs font-medium ${r.is_active ? 'bg-green-900/40 text-green-300' : 'bg-gray-800 text-gray-500'}">${r.is_active ? 'Active' : 'Inactive'}</span></td>
                      <td class="max-w-32 truncate px-4 py-3 text-xs text-gray-500">${r.reason ?? '—'}</td>
                      <td class="px-4 py-3"><a href="/admin/affiliate/${r.id}" class="text-xs text-green-400 hover:text-green-300">Edit</a></td>
                    </tr>
                  `).join('') : '<tr><td colspan="7" class="px-4 py-8 text-center text-sm text-gray-500">No rules yet.</td></tr>'}
                </tbody>
              </table>
            </div>
          </div>
        `
      } else {
        const res = await fetch(`${API_BASE}/v1/admin/affiliate/stats?days=30`, { headers })
        if (!res.ok) throw new Error(`API error ${res.status}`)
        type DayStat = { date: string; clicks: number }
        type TopAsin = { source_asin: string; clicks: number }
        type Revenue = { period_year: number; period_month: number; gross_usd: number; net_usd: number; total_clicks: number; total_orders: number }
        const { daily, topAsins, revenue }: { daily: DayStat[]; topAsins: TopAsin[]; revenue: Revenue[] } = await res.json()
        const maxClicks = Math.max(...daily.map(d => d.clicks), 1)

        document.getElementById('tab-content')!.innerHTML = `
          <div class="space-y-6">
            <div class="rounded-xl border border-gray-800 bg-gray-900 p-6">
              <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">Daily clicks (last 30 days)</h2>
              <div class="flex items-end gap-1 h-20">
                ${daily.length ? daily.map(d => `
                  <div class="flex-1 bg-green-600/60 rounded-sm" style="height:${Math.round(d.clicks/maxClicks*100)}%" title="${d.date}: ${d.clicks}"></div>
                `).join('') : '<p class="text-sm text-gray-500">No click data yet.</p>'}
              </div>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
                <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-400">Top ASINs (30d)</h2>
                ${topAsins.length ? topAsins.map(a => `
                  <div class="flex items-center justify-between py-1.5">
                    <span class="font-mono text-xs text-gray-300">${a.source_asin}</span>
                    <span class="text-sm font-semibold text-gray-200">${a.clicks}</span>
                  </div>
                `).join('') : '<p class="text-sm text-gray-500">No data yet.</p>'}
              </div>
              <div class="rounded-xl border border-gray-800 bg-gray-900 p-5">
                <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-400">Revenue snapshots</h2>
                ${revenue.length ? revenue.map(r => `
                  <div class="flex items-center justify-between border-t border-gray-800 py-2 first:border-t-0">
                    <div>
                      <p class="text-xs text-gray-400">${r.period_year}-${String(r.period_month).padStart(2,'0')}</p>
                      <p class="text-xs text-gray-500">${r.total_clicks} clicks · ${r.total_orders} orders</p>
                    </div>
                    <span class="text-sm font-semibold text-green-400">$${r.net_usd.toFixed(2)}</span>
                  </div>
                `).join('') : '<p class="text-sm text-gray-500">No revenue data yet.</p>'}
              </div>
            </div>
          </div>
        `
      }
    } catch (err) {
      const box = document.getElementById('error-box')!
      box.textContent = String(err)
      box.classList.remove('hidden')
    }
  }

  load()
</script>
