---
import Admin from '@/layouts/Admin.astro'
---
<Admin title="Estimations">
  <div class="mb-6 flex flex-wrap items-center gap-3">
    <span class="text-sm text-gray-400" id="total-label">Loading…</span>
    <div class="flex gap-2" id="tier-filters">
      <a href="/admin/footprints" class="rounded-full px-3 py-1 text-xs font-medium bg-gray-800 text-gray-400 hover:bg-gray-700" id="filter-all">All</a>
      <a href="?tier=1" class="rounded-full px-3 py-1 text-xs font-medium bg-gray-800 text-gray-400 hover:bg-gray-700">Tier 1</a>
      <a href="?tier=2" class="rounded-full px-3 py-1 text-xs font-medium bg-gray-800 text-gray-400 hover:bg-gray-700">Tier 2</a>
      <a href="?tier=3" class="rounded-full px-3 py-1 text-xs font-medium bg-gray-800 text-gray-400 hover:bg-gray-700">Tier 3</a>
    </div>
  </div>

  <div class="mb-6 grid gap-4 sm:grid-cols-3" id="tier-cards">
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-4 animate-pulse h-24"></div>
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-4 animate-pulse h-24"></div>
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-4 animate-pulse h-24"></div>
  </div>

  <div id="error-box" class="mb-4 hidden rounded-xl bg-red-900/20 border border-red-800 px-4 py-3 text-sm text-red-300"></div>

  <div class="overflow-hidden rounded-xl border border-gray-800" id="table-wrap">
    <div class="py-16 text-center text-sm text-gray-500">Loading…</div>
  </div>

  <div class="mt-4 flex items-center justify-between text-sm text-gray-400" id="pagination"></div>
</Admin>

<script>
  import { API_BASE } from '@/lib/config'

  const token = sessionStorage.getItem('admin_token')
  if (!token) { window.location.href = '/admin/login'; throw 0 }

  const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }
  const qs = new URLSearchParams(location.search)
  const tier = qs.get('tier') ?? ''
  const page = parseInt(qs.get('page') ?? '1', 10)

  // Highlight active filter
  if (!tier) document.getElementById('filter-all')!.className = 'rounded-full px-3 py-1 text-xs font-medium bg-green-700 text-white'
  else {
    document.querySelectorAll('#tier-filters a').forEach(a => {
      if ((a as HTMLAnchorElement).href.includes(`tier=${tier}`)) {
        a.className = 'rounded-full px-3 py-1 text-xs font-medium bg-green-700 text-white'
      }
    })
  }

  const tierColor = (t: number) => t === 1 ? 'bg-green-900/40 text-green-300' : t === 2 ? 'bg-yellow-900/40 text-yellow-300' : 'bg-red-900/40 text-red-300'
  const barColor = (t: number) => t === 1 ? 'bg-green-500' : t === 2 ? 'bg-yellow-500' : 'bg-red-500'

  async function load() {
    try {
      const params = new URLSearchParams({ page: String(page), pageSize: '50' })
      if (tier) params.set('tier', tier)
      const res = await fetch(`${API_BASE}/v1/admin/estimations?${params}`, { headers })
      if (!res.ok) throw new Error(`API error ${res.status}`)
      type Est = { id: number; domain: string; product_name: string | null; estimated_co2e_kg: number; confidence: number; tier: number; created_at: string; category_slug: string | null }
      type TierStat = { tier: number; count: number; avg_confidence: number }
      const data: { data: Est[]; total: number; tierStats: TierStat[]; page: number } = await res.json()
      const totalPages = Math.ceil(data.total / 50)

      document.getElementById('total-label')!.textContent = `${data.total} total`

      document.getElementById('tier-cards')!.innerHTML = data.tierStats.map(t => `
        <div class="rounded-xl border border-gray-800 bg-gray-900 p-4">
          <div class="mb-2 flex items-center justify-between">
            <span class="rounded-full px-2 py-0.5 text-xs font-bold ${tierColor(t.tier)}">Tier ${t.tier}</span>
            <span class="text-xs text-gray-400">${t.count} runs</span>
          </div>
          <p class="mb-1 text-xs text-gray-500">Avg confidence</p>
          <div class="flex items-center gap-2">
            <div class="flex-1 h-2 rounded-full bg-gray-800">
              <div class="h-2 rounded-full ${barColor(t.tier)}" style="width:${(t.avg_confidence*100).toFixed(0)}%"></div>
            </div>
            <span class="text-sm font-semibold text-gray-200">${(t.avg_confidence*100).toFixed(0)}%</span>
          </div>
        </div>
      `).join('')

      document.getElementById('table-wrap')!.innerHTML = `
        <table class="w-full text-sm">
          <thead class="border-b border-gray-800 bg-gray-900/60">
            <tr class="text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
              <th class="px-4 py-3">Product</th><th class="px-4 py-3">Domain</th>
              <th class="px-4 py-3">Category</th><th class="px-4 py-3">CO₂e</th>
              <th class="px-4 py-3">Confidence</th><th class="px-4 py-3">Tier</th><th class="px-4 py-3">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800 bg-gray-900">
            ${data.data.map(e => `
              <tr class="hover:bg-gray-800/40">
                <td class="max-w-48 truncate px-4 py-3 font-medium text-gray-200">${e.product_name ?? '—'}</td>
                <td class="px-4 py-3 text-gray-400 text-xs">${e.domain}</td>
                <td class="px-4 py-3 text-gray-400 text-xs">${e.category_slug ?? '—'}</td>
                <td class="px-4 py-3 text-gray-300">${e.estimated_co2e_kg} kg</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1.5">
                    <div class="w-16 h-1.5 rounded-full bg-gray-800">
                      <div class="h-1.5 rounded-full bg-green-500" style="width:${(e.confidence*100).toFixed(0)}%"></div>
                    </div>
                    <span class="text-xs text-gray-400">${(e.confidence*100).toFixed(0)}%</span>
                  </div>
                </td>
                <td class="px-4 py-3"><span class="rounded-full px-2 py-0.5 text-xs font-bold ${tierColor(e.tier)}">T${e.tier}</span></td>
                <td class="px-4 py-3 text-xs text-gray-500">${e.created_at.slice(0,10)}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      `

      if (totalPages > 1) {
        document.getElementById('pagination')!.innerHTML = `
          <span>Page ${page} of ${totalPages}</span>
          <div class="flex gap-2">
            ${page > 1 ? `<a href="?page=${page-1}${tier?`&tier=${tier}`:''}" class="rounded-lg border border-gray-700 px-3 py-1.5 hover:border-gray-600">← Prev</a>` : ''}
            ${page < totalPages ? `<a href="?page=${page+1}${tier?`&tier=${tier}`:''}" class="rounded-lg border border-gray-700 px-3 py-1.5 hover:border-gray-600">Next →</a>` : ''}
          </div>
        `
      }
    } catch (err) {
      const box = document.getElementById('error-box')!
      box.textContent = String(err)
      box.classList.remove('hidden')
    }
  }

  load()
</script>
