---
import Marketing from '@/layouts/Marketing.astro'
---
<Marketing title="Your impact">
  <div class="mx-auto max-w-4xl px-6 py-16">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="mb-2 text-3xl font-bold text-gray-900">Your impact</h1>
      <p class="text-gray-500">
        Every greener choice you make through Better Cart is tracked locally.
        No account needed — your data never leaves your browser.
      </p>
    </div>

    <!-- Not installed banner (shown until extension responds) -->
    <div id="no-extension" class="mb-8 hidden rounded-2xl border border-amber-200 bg-amber-50 px-6 py-5 flex items-center gap-4">
      <svg class="shrink-0 text-amber-500" width="20" height="20" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
        <path d="M12 8v4m0 4h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <div>
        <p class="text-sm font-medium text-amber-800">Extension not detected</p>
        <p class="text-sm text-amber-700">
          <a href="/install" class="underline">Install Better Cart</a> to start tracking your personal carbon savings.
        </p>
      </div>
    </div>

    <!-- Stats row -->
    <div class="mb-10 grid gap-5 sm:grid-cols-3">
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm text-center">
        <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">CO₂e avoided</p>
        <p class="text-4xl font-black text-green-600" id="stat-co2">—</p>
        <p class="mt-1 text-sm text-gray-400">kg</p>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm text-center">
        <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Greener choices</p>
        <p class="text-4xl font-black text-gray-900" id="stat-clicks">—</p>
        <p class="mt-1 text-sm text-gray-400">clicks</p>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm text-center">
        <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Pages scanned</p>
        <p class="text-4xl font-black text-gray-900" id="stat-scans">—</p>
        <p class="mt-1 text-sm text-gray-400">products</p>
      </div>
    </div>

    <!-- Recent choices -->
    <div class="mb-10">
      <h2 class="mb-4 text-lg font-semibold text-gray-900">Recent greener choices</h2>
      <div id="recent-choices" class="space-y-3">
        <div class="rounded-xl border border-gray-100 bg-gray-50 px-5 py-4 text-sm text-gray-400">
          No greener choices recorded yet. Browse some products with the extension active.
        </div>
      </div>
    </div>

    <!-- Category breakdown -->
    <div class="mb-10">
      <h2 class="mb-4 text-lg font-semibold text-gray-900">Savings by category</h2>
      <div id="category-breakdown" class="space-y-3">
        <div class="rounded-xl border border-gray-100 bg-gray-50 px-5 py-4 text-sm text-gray-400">
          No category data yet.
        </div>
      </div>
    </div>

    <!-- Equivalent comparisons -->
    <div id="equivalents-section" class="hidden rounded-2xl border border-green-100 bg-green-50 px-6 py-5">
      <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-green-600">That's equivalent to…</p>
      <ul id="equivalents-list" class="mt-2 space-y-1 text-sm text-green-800"></ul>
    </div>

  </div>
</Marketing>

<script>
// Pull data from the extension via chrome.storage (shared with the extension's service worker)
// Falls back gracefully if extension isn't installed.

interface ImpactEvent {
  domain: string
  baselineCo2eKg: number
  alternativeCo2eKg: number
  savingKg: number
  categorySlug: string | null
  productName: string | null
  alternativeName: string | null
  ts: number
}

interface ExtStorage {
  impactEvents?: ImpactEvent[]
  totalScans?: number
}

function formatKg(kg: number): string {
  return kg >= 1 ? kg.toFixed(1) : (kg * 1000).toFixed(0) + ' g'
}

function equivalents(kg: number): string[] {
  const out: string[] = []
  if (kg >= 0.12) out.push(`${(kg / 0.12).toFixed(0)} km driven in an average petrol car`)
  if (kg >= 0.05) out.push(`${(kg / 0.05).toFixed(0)} streaming hours avoided (CO₂e)`)
  if (kg >= 0.3)  out.push(`${(kg / 0.3).toFixed(1)} kg of beef not eaten`)
  return out.slice(0, 2)
}

async function load(): Promise<void> {
  // Check if chrome extension API is available
  if (typeof chrome === 'undefined' || !chrome.storage) {
    document.getElementById('no-extension')!.classList.remove('hidden')
    return
  }

  try {
    const result: ExtStorage = await new Promise((resolve) =>
      chrome.storage.local.get(['impactEvents', 'totalScans'], resolve as (v: ExtStorage) => void)
    )

    const events: ImpactEvent[] = result.impactEvents ?? []
    const totalScans: number = result.totalScans ?? 0
    const totalSaving = events.reduce((sum, e) => sum + e.savingKg, 0)

    // Stats
    document.getElementById('stat-co2')!.textContent = formatKg(totalSaving)
    document.getElementById('stat-clicks')!.textContent = String(events.length)
    document.getElementById('stat-scans')!.textContent = String(totalScans)

    // Recent choices
    if (events.length > 0) {
      const recent = [...events].sort((a, b) => b.ts - a.ts).slice(0, 8)
      document.getElementById('recent-choices')!.innerHTML = recent.map(e => `
        <div class="flex items-center justify-between rounded-xl border border-gray-100 bg-white px-5 py-3 shadow-sm">
          <div class="min-w-0">
            <p class="truncate text-sm font-medium text-gray-800">${e.alternativeName ?? 'Greener alternative'}</p>
            <p class="text-xs text-gray-400">${e.domain} · ${new Date(e.ts).toLocaleDateString()}</p>
          </div>
          <span class="ml-4 shrink-0 rounded-full bg-green-100 px-3 py-1 text-xs font-bold text-green-700">
            −${formatKg(e.savingKg)} CO₂e
          </span>
        </div>
      `).join('')
    }

    // Category breakdown
    const byCat: Record<string, number> = {}
    for (const e of events) {
      const cat = e.categorySlug ?? 'general'
      byCat[cat] = (byCat[cat] ?? 0) + e.savingKg
    }
    const sorted = Object.entries(byCat).sort((a, b) => b[1] - a[1])
    if (sorted.length > 0) {
      const max = sorted[0]![1]
      document.getElementById('category-breakdown')!.innerHTML = sorted.map(([cat, kg]) => `
        <div>
          <div class="mb-1 flex justify-between text-xs text-gray-500">
            <span class="capitalize">${cat.replace('/', ' › ')}</span>
            <span class="font-medium text-gray-700">${formatKg(kg)}</span>
          </div>
          <div class="h-2 rounded-full bg-gray-100">
            <div class="h-2 rounded-full bg-green-500" style="width:${(kg / max * 100).toFixed(0)}%"></div>
          </div>
        </div>
      `).join('')
    }

    // Equivalents
    if (totalSaving > 0.1) {
      const eqs = equivalents(totalSaving)
      if (eqs.length > 0) {
        document.getElementById('equivalents-section')!.classList.remove('hidden')
        document.getElementById('equivalents-list')!.innerHTML =
          eqs.map(e => `<li>• ${e}</li>`).join('')
      }
    }

  } catch {
    document.getElementById('no-extension')!.classList.remove('hidden')
  }
}

document.addEventListener('DOMContentLoaded', () => { load() })
</script>
