---
import Marketing from '@/layouts/Marketing.astro'
---
<Marketing title="Shop greener">

  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-50 to-white px-6 py-20 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="mb-4 text-5xl font-bold leading-tight tracking-tight text-gray-900">
        Know the carbon cost<br />before you buy
      </h1>
      <p class="mb-10 text-xl leading-relaxed text-gray-500">
        Search any product, see its CO₂ footprint, and find a greener alternative — right here, no extension needed.
      </p>

      <!-- Search bar -->
      <form id="hero-search" action="/catalogue" method="get" class="mx-auto mb-4 flex max-w-xl overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-md focus-within:border-green-400 focus-within:ring-2 focus-within:ring-green-100">
        <input
          id="hero-input"
          type="text"
          name="search"
          placeholder="Search products, paste an Amazon URL…"
          class="flex-1 bg-transparent px-5 py-4 text-base text-gray-800 placeholder-gray-400 outline-none"
          autofocus
        />
        <button
          type="submit"
          class="m-1.5 rounded-xl bg-green-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-green-700"
        >
          Search
        </button>
      </form>
      <p id="url-error" class="hidden mb-2 text-sm text-red-500">Product not found in our catalogue yet.</p>

      <div class="flex items-center justify-center gap-4 text-sm text-gray-500">
        <a href="/catalogue" class="font-medium text-green-700 hover:underline">Browse all products →</a>
        <span class="text-gray-300">|</span>
        <a href="/install" class="hover:text-gray-700">Get the extension</a>
      </div>
    </div>
  </section>

  <!-- Live impact counter -->
  <section class="bg-green-900 px-6 py-16 text-center text-white">
    <div class="mx-auto max-w-4xl">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-green-300">Real impact, tracked live</p>
      <h2 class="mb-8 text-3xl font-bold">Right Choice users have already saved</h2>
      <div class="grid gap-8 sm:grid-cols-2">
        <div>
          <p class="text-5xl font-black text-green-300" id="stat-co2e">—</p>
          <p class="mt-2 text-sm text-green-200">kg CO₂e avoided</p>
        </div>
        <div>
          <p class="text-5xl font-black text-green-300" id="stat-events">—</p>
          <p class="mt-2 text-sm text-green-200">greener alternatives recommended</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Category quick-nav (loaded dynamically) -->
  <section class="border-b border-gray-100 bg-white px-6 py-6">
    <div class="mx-auto max-w-6xl">
      <div id="category-chips" class="flex flex-wrap gap-2">
        {[0,1,2,3,4,5,6].map(() => (
          <div class="h-8 w-24 animate-pulse rounded-full bg-gray-100"></div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured products -->
  <section class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Lowest footprint picks</h2>
          <p class="text-sm text-gray-500">Products with the smallest lifecycle CO₂e in our catalogue</p>
        </div>
        <a href="/catalogue" class="text-sm font-medium text-green-700 hover:underline">View all →</a>
      </div>
      <div id="featured-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[0,1,2,3].map(() => (
          <div class="h-52 animate-pulse rounded-2xl bg-gray-100"></div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works — dual mode -->
  <section class="bg-gray-50 px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="mb-2 text-center text-3xl font-bold text-gray-900">Two ways to use Right Choice</h2>
      <p class="mb-12 text-center text-gray-500">Use the web app on any device, or install the extension for always-on scores while you browse.</p>

      <div class="grid gap-8 md:grid-cols-2">
        <!-- Web app -->
        <div class="rounded-2xl border border-green-200 bg-white p-8 shadow-sm">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-green-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-green-700">
            Web app — no install needed
          </div>
          <ol class="space-y-4">
            {[
              { n: '1', t: 'Search', d: 'Type a product name or brand in the search bar above.' },
              { n: '2', t: 'See the footprint', d: 'Browse CO₂e scores, certifications, and lifecycle data.' },
              { n: '3', t: 'Pick greener', d: 'Compare alternatives ranked lowest-to-highest impact.' },
            ].map(({ n, t, d }) => (
              <li class="flex gap-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-green-600 text-sm font-bold text-white">{n}</span>
                <div>
                  <p class="font-semibold text-gray-900">{t}</p>
                  <p class="text-sm text-gray-500">{d}</p>
                </div>
              </li>
            ))}
          </ol>
          <a href="/catalogue" class="mt-6 inline-block rounded-xl border border-green-600 px-5 py-2.5 text-sm font-semibold text-green-700 hover:bg-green-50">
            Open catalogue →
          </a>
        </div>

        <!-- Extension -->
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-gray-600">
            Browser extension — always on
          </div>
          <ol class="space-y-4">
            {[
              { n: '1', t: 'Install once', d: 'Add to Chrome or Firefox in one click. No account required.' },
              { n: '2', t: 'Browse normally', d: 'Visit any product page — Amazon, Zalando, wherever.' },
              { n: '3', t: 'See scores inline', d: 'A banner appears automatically with the CO₂e score and greener alternatives.' },
            ].map(({ n, t, d }) => (
              <li class="flex gap-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-200 text-sm font-bold text-gray-700">{n}</span>
                <div>
                  <p class="font-semibold text-gray-900">{t}</p>
                  <p class="text-sm text-gray-500">{d}</p>
                </div>
              </li>
            ))}
          </ol>
          <a href="/install" class="mt-6 inline-block rounded-xl bg-green-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-green-700">
            Install extension →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footprint Protocol / Verified scores -->
  <section class="px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <h2 class="mb-4 text-3xl font-bold text-gray-900">Always a score, never a guess</h2>
          <p class="mb-6 leading-relaxed text-gray-600">
            When a product carries <a href="https://footprint.c22.foundation/" target="_blank" class="font-medium text-green-700 underline underline-offset-2">Footprint Protocol</a> tags,
            Right Choice reads the exact lifecycle CO₂e. When it doesn't, a three-tier
            estimation protocol derives a figure from material composition, weight, and origin signals.
          </p>
          <p class="text-sm text-gray-500">
            Every score shows its source:
            <span class="rounded bg-green-100 px-1.5 py-0.5 text-xs font-medium text-green-700">Verified</span> for tagged products,
            <span class="rounded bg-yellow-100 px-1.5 py-0.5 text-xs font-medium text-yellow-700">Estimated</span> for everything else.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <div class="mb-3 rounded-xl border border-green-100 bg-green-50 p-4">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-800">Fairphone 5</span>
              <span class="rounded-full bg-green-600 px-2.5 py-0.5 text-xs font-bold text-white">Verified</span>
            </div>
            <p class="mb-1 text-2xl font-bold text-green-700">29.4 kg CO₂e</p>
            <p class="text-xs text-gray-500">Lifecycle · 30% below category average</p>
          </div>
          <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 opacity-70">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-800">Generic Phone</span>
              <span class="rounded-full bg-yellow-400 px-2.5 py-0.5 text-xs font-bold text-gray-800">Estimated T2</span>
            </div>
            <p class="mb-1 text-2xl font-bold text-gray-700">~42 kg CO₂e</p>
            <p class="text-xs text-gray-500">Weight-scaled category average</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- For Sellers -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <div class="rounded-3xl border border-gray-200 bg-gradient-to-br from-green-50 to-white p-10 shadow-sm">
        <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-green-600">For sellers</div>
        <h2 class="mb-4 text-3xl font-bold text-gray-900">Tag your products. Get a verified score.</h2>
        <p class="mb-8 max-w-2xl leading-relaxed text-gray-600">
          Products with <a href="https://footprint.c22.foundation/" target="_blank" rel="noopener" class="font-medium text-green-700 underline underline-offset-2">Footprint Protocol</a>
          tags get a verified badge — not an estimate. They rank higher in alternatives and build buyer trust.
        </p>
        <div class="mb-8 rounded-xl bg-gray-900 p-5">
          <p class="mb-3 text-xs font-semibold text-gray-400">Add to your &lt;head&gt;</p>
          <pre class="overflow-x-auto font-mono text-sm text-green-300"><code>{`<meta property="fp:product"   content="Your Product Name" />
<meta property="fp:co2e"      content="12.4" />
<meta property="fp:co2e:unit" content="kg" />
<meta property="fp:scope"     content="lifecycle" />`}</code></pre>
        </div>
        <a href="https://footprint.c22.foundation/" target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-6 py-3 text-sm font-semibold text-white hover:bg-green-700">
          Read the Footprint Protocol →
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-green-700 px-6 py-20 text-center text-white">
    <div class="mx-auto max-w-2xl">
      <h2 class="mb-4 text-3xl font-bold">Start shopping with a conscience</h2>
      <p class="mb-8 text-green-100">Free. Open source. No data sold. Ever.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/catalogue" class="rounded-xl bg-white px-8 py-3.5 text-base font-semibold text-green-700 hover:bg-green-50">
          Browse catalogue
        </a>
        <a href="/install" class="rounded-xl border border-green-300 px-8 py-3.5 text-base font-semibold text-white hover:border-white">
          Install extension
        </a>
      </div>
    </div>
  </section>

</Marketing>

<script>
  import { API_BASE } from '@/lib/config'

  // URL paste detection
  const btn = document.querySelector('#hero-search button[type="submit"]') as HTMLButtonElement

  document.getElementById('hero-search')!.addEventListener('submit', async (e) => {
    const val = (document.getElementById('hero-input') as HTMLInputElement).value.trim()
    if (!val.startsWith('http')) return // let normal form submit handle it
    e.preventDefault()
    document.getElementById('url-error')!.classList.add('hidden')
    btn.textContent = 'Loading…'
    btn.disabled = true

    try {
      const res = await fetch(`${API_BASE}/v1/footprint/from-url`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: val }),
      })
      if (!res.ok) throw new Error()
      const data = await res.json() as { source: string; product?: { id: number }; estimate?: { co2eKg: number; tier: number } }
      if (data.source === 'catalogue' && data.product) {
        window.location.href = `/product?id=${data.product.id}`
      } else if (data.estimate) {
        // Show inline estimate result
        const co2e = data.estimate.co2eKg?.toFixed(1) ?? '?'
        const tier = data.estimate.tier ?? '?'
        document.getElementById('url-error')!.textContent = `Estimated footprint: ~${co2e} kg CO₂e (Tier ${tier} estimate). Not in catalogue yet.`
        document.getElementById('url-error')!.classList.remove('hidden', 'text-red-500')
        document.getElementById('url-error')!.classList.add('text-green-700')
      } else {
        throw new Error()
      }
    } catch {
      document.getElementById('url-error')!.textContent = 'Could not analyse this URL. Try searching by product name.'
      document.getElementById('url-error')!.classList.remove('hidden')
    } finally {
      btn.textContent = 'Search'
      btn.disabled = false
    }
  })

  // Load category chips
  fetch(`${API_BASE}/v1/catalogue/categories`).then(r => r.ok ? r.json() : null).then((data) => {
    if (!data?.categories) return
    type Cat = { slug: string; name: string; parent_id: number | null }
    const top: Cat[] = data.categories.filter((c: Cat) => c.parent_id === null).slice(0, 10)
    document.getElementById('category-chips')!.innerHTML = top.map(c =>
      `<a href="/catalogue?category=${c.slug}" class="rounded-full border border-gray-200 bg-white px-4 py-1.5 text-sm font-medium text-gray-600 hover:border-green-400 hover:text-green-700 transition">${c.name}</a>`
    ).join('')
  }).catch(() => {})

  // Load featured products (lowest CO2e)
  fetch(`${API_BASE}/v1/catalogue/products?pageSize=4`).then(r => r.ok ? r.json() : null).then((data) => {
    if (!data?.data) return
    type Product = { id: number; name: string; brand: string; co2e_kg: number; co2e_source: string; image_url: string | null }
    const products: Product[] = data.data
    const color = (kg: number) => kg < 10 ? 'text-green-600' : kg < 30 ? 'text-yellow-600' : 'text-red-500'
    const badge = (src: string) => src === 'certified' || src === 'fp_tag'
      ? '<span class="rounded-full bg-green-100 px-2 py-0.5 text-[10px] font-bold text-green-700">Verified</span>'
      : '<span class="rounded-full bg-yellow-100 px-2 py-0.5 text-[10px] font-bold text-yellow-700">Estimated</span>'

    document.getElementById('featured-grid')!.innerHTML = products.map(p => `
      <a href="/catalogue?search=${encodeURIComponent(p.name)}"
        class="group flex flex-col rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:border-gray-200 hover:shadow-md">
        ${p.image_url ? `<img src="${p.image_url}" alt="${p.name}" class="mb-4 h-28 w-full rounded-xl object-contain bg-gray-50" loading="lazy" />` : '<div class="mb-4 h-28 w-full rounded-xl bg-gray-50"></div>'}
        <p class="mb-0.5 text-xs font-medium uppercase tracking-wider text-gray-400">${p.brand}</p>
        <h3 class="mb-3 flex-1 text-sm font-semibold leading-snug text-gray-900 group-hover:text-green-700">${p.name}</h3>
        <div>
          <div class="mb-1 flex items-baseline gap-1">
            <span class="text-xl font-black ${color(p.co2e_kg)}">${p.co2e_kg.toFixed(1)}</span>
            <span class="text-xs text-gray-400">kg CO₂e</span>
          </div>
          ${badge(p.co2e_source)}
        </div>
      </a>
    `).join('')
  }).catch(() => {})

  // Impact stats
  fetch(`${API_BASE}/v1/impact/stats`).then(r => r.ok ? r.json() : null).then(data => {
    if (!data?.totals) return
    const t = data.totals
    document.getElementById('stat-co2e')!.textContent = t.total_saving_co2e_kg.toFixed(1)
    document.getElementById('stat-events')!.textContent = t.total_events.toLocaleString()
    document.getElementById('stat-sessions')!.textContent = t.unique_sessions.toLocaleString()
  }).catch(() => {})
</script>
