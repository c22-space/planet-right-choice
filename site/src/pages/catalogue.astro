---
import Marketing from '@/layouts/Marketing.astro'
---
<Marketing title="Catalogue">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="mb-8">
      <h1 class="mb-2 text-3xl font-bold text-gray-900">Green catalogue</h1>
      <p class="text-gray-500" id="total-label">Loading products…</p>

      <!-- Search bar -->
      <form id="search-form" class="mt-4 flex max-w-lg overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm focus-within:border-green-400 focus-within:ring-2 focus-within:ring-green-100">
        <input
          id="search-input"
          type="text"
          name="search"
          placeholder="Search products or brands…"
          class="flex-1 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 outline-none"
        />
        <button type="submit" class="m-1 rounded-lg bg-green-600 px-4 py-1.5 text-sm font-semibold text-white hover:bg-green-700">
          Search
        </button>
      </form>
    </div>

    <div class="flex gap-8">
      <!-- Sidebar: category filter -->
      <aside class="hidden w-48 shrink-0 md:block">
        <p class="mb-3 text-xs font-bold uppercase tracking-wider text-gray-400">Category</p>
        <nav class="space-y-1" id="cat-nav">
          <a href="/catalogue" class="block rounded-lg px-3 py-2 text-sm font-medium bg-green-50 text-green-700">All products</a>
        </nav>
      </aside>

      <!-- Product grid -->
      <div class="flex-1">
        <div class="mb-6 md:hidden">
          <select id="cat-select" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm">
            <option value="">All categories</option>
          </select>
        </div>

        <div id="product-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {[0,1,2,3,4,5].map(() => (
            <div class="rounded-2xl border border-gray-100 bg-gray-50 p-5 animate-pulse h-48"></div>
          ))}
        </div>

        <div class="mt-10 flex items-center justify-center gap-2" id="pagination"></div>
      </div>
    </div>
  </div>
</Marketing>

<script>
  import { API_BASE } from '@/lib/config'

  const qs = new URLSearchParams(location.search)
  let category = qs.get('category') ?? ''
  let search = qs.get('search') ?? ''
  let page = Math.max(1, parseInt(qs.get('page') ?? '1', 10))
  const pageSize = 20

  // Pre-fill search input
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  if (search) searchInput.value = search

  document.getElementById('search-form')!.addEventListener('submit', (e) => {
    e.preventDefault()
    const q = searchInput.value.trim()
    const params = new URLSearchParams()
    if (q) params.set('search', q)
    if (category) params.set('category', category)
    window.location.href = `/catalogue?${params}`
  })

  const sourceLabel = (s: string) => (s === 'certified' || s === 'fp_tag') ? 'Verified' : s === 'manual' ? 'Manual' : 'Estimated'
  const sourceBadge = (s: string) => (s === 'certified' || s === 'fp_tag') ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'
  const co2eColor = (kg: number, avg = 30) => {
    const r = kg / avg
    return r < 0.6 ? 'text-green-600' : r < 1.0 ? 'text-yellow-600' : 'text-red-500'
  }

  async function loadCategories() {
    try {
      const res = await fetch(`${API_BASE}/v1/catalogue/categories`)
      if (!res.ok) return
      type Category = { id: number; slug: string; name: string; parent_id: number | null }
      const { categories }: { categories: Category[] } = await res.json()
      const top = categories.filter(c => c.parent_id === null)

      const nav = document.getElementById('cat-nav')!
      nav.innerHTML = `
        <a href="/catalogue" class="block rounded-lg px-3 py-2 text-sm font-medium ${!category ? 'bg-green-50 text-green-700' : 'text-gray-600 hover:bg-gray-50'}">All products</a>
        ${top.map(c => `
          <a href="/catalogue?category=${c.slug}" class="block rounded-lg px-3 py-2 text-sm font-medium ${category === c.slug ? 'bg-green-50 text-green-700' : 'text-gray-600 hover:bg-gray-50'}">${c.name}</a>
        `).join('')}
      `

      const sel = document.getElementById('cat-select') as HTMLSelectElement
      sel.innerHTML = `<option value="">All categories</option>` + top.map(c =>
        `<option value="${c.slug}" ${category === c.slug ? 'selected' : ''}>${c.name}</option>`
      ).join('')
      sel.addEventListener('change', () => {
        window.location.href = sel.value ? `/catalogue?category=${sel.value}` : '/catalogue'
      })
    } catch {}
  }

  async function loadProducts(p: number) {
    try {
      const params = new URLSearchParams({ page: String(p), pageSize: String(pageSize) })
      if (category) params.set('category', category)
      if (search) params.set('search', search)
      const res = await fetch(`${API_BASE}/v1/catalogue/products?${params}`)
      if (!res.ok) throw new Error(`API error ${res.status}`)
      type Product = { id: number; name: string; brand: string; co2e_kg: number; co2e_source: string; certifications: string | null; url: string | null; image_url: string | null; origin_country: string | null }
      const { data, total }: { data: Product[]; total: number } = await res.json()
      const totalPages = Math.ceil(total / pageSize)

      document.getElementById('total-label')!.textContent = `${total.toLocaleString()} products ranked by lifecycle CO₂e. Lower is greener.`

      document.getElementById('product-grid')!.innerHTML = data.length ? data.map(p => {
        const certs: string[] = (() => { try { return JSON.parse(p.certifications ?? '[]') } catch { return [] } })()
        return `
          <a href="/product?id=${p.id}"
            class="group flex flex-col rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:border-gray-200 hover:shadow-md">
            ${p.image_url ? `<img src="${p.image_url}" alt="${p.name}" class="mb-4 h-32 w-full rounded-xl object-contain bg-gray-50" loading="lazy" />` : ''}
            <p class="mb-0.5 text-xs font-medium uppercase tracking-wider text-gray-400">${p.brand ?? ''}</p>
            <h2 class="mb-3 text-sm font-semibold leading-snug text-gray-900 group-hover:text-green-700">${p.name}</h2>
            <div class="mt-auto">
              <div class="mb-2 flex items-baseline gap-1.5">
                <span class="text-2xl font-black ${co2eColor(p.co2e_kg)}">${p.co2e_kg.toFixed(1)}</span>
                <span class="text-xs text-gray-400">kg CO₂e</span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                <span class="rounded-full px-2 py-0.5 text-[10px] font-bold ${sourceBadge(p.co2e_source)}">${sourceLabel(p.co2e_source)}</span>
                ${p.origin_country ? `<span class="rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-500">${p.origin_country}</span>` : ''}
                ${certs.slice(0,2).map((c: string) => `<span class="rounded-full bg-blue-50 px-2 py-0.5 text-[10px] font-medium text-blue-600">${c}</span>`).join('')}
              </div>
            </div>
          </a>
        `
      }).join('') : '<div class="col-span-3 rounded-2xl border border-gray-100 bg-gray-50 py-20 text-center text-gray-400">No products found.</div>'

      if (totalPages > 1) {
        const base = [category ? `category=${category}` : '', search ? `search=${encodeURIComponent(search)}` : ''].filter(Boolean).join('&')
        const sep = base ? `${base}&` : ''
        document.getElementById('pagination')!.innerHTML = `
          ${p > 1 ? `<a href="?${sep}page=${p-1}" class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50">← Previous</a>` : ''}
          <span class="text-sm text-gray-400">Page ${p} of ${totalPages}</span>
          ${p < totalPages ? `<a href="?${sep}page=${p+1}" class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50">Next →</a>` : ''}
        `
      }
    } catch (err) {
      document.getElementById('product-grid')!.innerHTML = `
        <div class="col-span-3 rounded-2xl border border-red-100 bg-red-50 py-20 text-center text-red-500">${err}</div>
      `
    }
  }

  loadCategories()
  loadProducts(page)
</script>
