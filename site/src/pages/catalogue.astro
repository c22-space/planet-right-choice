---
import Marketing from '@/layouts/Marketing.astro'
import { apiGet } from '@/lib/api'

const env = (Astro.locals as Record<string, unknown>)['runtime']?.['env']

const url = Astro.url
const category = url.searchParams.get('category') ?? ''
const page = Math.max(1, parseInt(url.searchParams.get('page') ?? '1', 10))

interface Category {
  id: number
  slug: string
  name: string
  parent_id: number | null
  avg_co2e_kg: number | null
}

interface Product {
  id: number
  name: string
  brand: string
  co2e_kg: number
  co2e_source: string
  co2e_confidence: number
  certifications: string | null
  url: string | null
  image_url: string | null
  origin_country: string | null
  category_id: number
}

interface ProductsResponse {
  data: Product[]
  total: number
  page: number
  pageSize: number
}

let categories: Category[] = []
let products: Product[] = []
let total = 0
const pageSize = 20

try {
  const [catRes, prodRes] = await Promise.all([
    apiGet<{ categories: Category[] }>('/v1/catalogue/categories', env),
    apiGet<ProductsResponse>(
      `/v1/catalogue/products?page=${page}&pageSize=${pageSize}${category ? `&category=${encodeURIComponent(category)}` : ''}`,
      env,
    ),
  ])
  categories = catRes.categories.filter((c) => c.parent_id === null)
  products = prodRes.data
  total = prodRes.total
} catch {
  // API unavailable — show empty state
}

const totalPages = Math.ceil(total / pageSize)

function sourceLabel(source: string): string {
  if (source === 'certified' || source === 'fp_tag') return 'Verified'
  if (source === 'manual') return 'Manual'
  return 'Estimated'
}

function sourceBadgeClass(source: string): string {
  if (source === 'certified' || source === 'fp_tag') return 'bg-green-100 text-green-700'
  return 'bg-yellow-100 text-yellow-700'
}

function co2eColor(kg: number, avg = 30): string {
  const ratio = kg / avg
  if (ratio < 0.6) return 'text-green-600'
  if (ratio < 1.0) return 'text-yellow-600'
  return 'text-red-500'
}
---

<Marketing title="Catalogue">
  <div class="mx-auto max-w-6xl px-6 py-12">

    <div class="mb-8">
      <h1 class="mb-2 text-3xl font-bold text-gray-900">Green catalogue</h1>
      <p class="text-gray-500">
        {total.toLocaleString()} products ranked by lifecycle CO₂e. Lower is greener.
      </p>
    </div>

    <div class="flex gap-8">
      <!-- Sidebar: category filter -->
      <aside class="hidden w-48 shrink-0 md:block">
        <p class="mb-3 text-xs font-bold uppercase tracking-wider text-gray-400">Category</p>
        <nav class="space-y-1">
          <a
            href="/catalogue"
            class={`block rounded-lg px-3 py-2 text-sm font-medium ${!category ? 'bg-green-50 text-green-700' : 'text-gray-600 hover:bg-gray-50'}`}
          >
            All products
          </a>
          {categories.map((cat) => (
            <a
              href={`/catalogue?category=${cat.slug}`}
              class={`block rounded-lg px-3 py-2 text-sm font-medium ${category === cat.slug ? 'bg-green-50 text-green-700' : 'text-gray-600 hover:bg-gray-50'}`}
            >
              {cat.name}
            </a>
          ))}
        </nav>
      </aside>

      <!-- Product grid -->
      <div class="flex-1">
        <!-- Mobile category select -->
        <div class="mb-6 md:hidden">
          <form method="get">
            <select
              name="category"
              onchange="this.form.submit()"
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm"
            >
              <option value="">All categories</option>
              {categories.map((cat) => (
                <option value={cat.slug} selected={category === cat.slug}>{cat.name}</option>
              ))}
            </select>
          </form>
        </div>

        {products.length === 0 ? (
          <div class="rounded-2xl border border-gray-100 bg-gray-50 py-20 text-center text-gray-400">
            No products found.
          </div>
        ) : (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {products.map((p) => {
              const certs: string[] = (() => {
                try { return JSON.parse(p.certifications ?? '[]') } catch { return [] }
              })()
              return (
                <a
                  href={p.url ?? '#'}
                  target={p.url ? '_blank' : undefined}
                  rel="noopener"
                  class="group flex flex-col rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:border-gray-200 hover:shadow-md"
                >
                  {p.image_url && (
                    <img
                      src={p.image_url}
                      alt={p.name}
                      class="mb-4 h-32 w-full rounded-xl object-contain bg-gray-50"
                      loading="lazy"
                    />
                  )}
                  <p class="mb-0.5 text-xs font-medium uppercase tracking-wider text-gray-400">{p.brand}</p>
                  <h2 class="mb-3 text-sm font-semibold leading-snug text-gray-900 group-hover:text-green-700">
                    {p.name}
                  </h2>

                  <!-- CO₂e score -->
                  <div class="mt-auto">
                    <div class="mb-2 flex items-baseline gap-1.5">
                      <span class={`text-2xl font-black ${co2eColor(p.co2e_kg)}`}>
                        {p.co2e_kg.toFixed(1)}
                      </span>
                      <span class="text-xs text-gray-400">kg CO₂e</span>
                    </div>

                    <div class="flex flex-wrap gap-1.5">
                      <span class={`rounded-full px-2 py-0.5 text-[10px] font-bold ${sourceBadgeClass(p.co2e_source)}`}>
                        {sourceLabel(p.co2e_source)}
                      </span>
                      {p.origin_country && (
                        <span class="rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-500">
                          {p.origin_country}
                        </span>
                      )}
                      {certs.slice(0, 2).map((c: string) => (
                        <span class="rounded-full bg-blue-50 px-2 py-0.5 text-[10px] font-medium text-blue-600">{c}</span>
                      ))}
                    </div>
                  </div>
                </a>
              )
            })}
          </div>
        )}

        <!-- Pagination -->
        {totalPages > 1 && (
          <div class="mt-10 flex items-center justify-center gap-2">
            {page > 1 && (
              <a
                href={`/catalogue?${category ? `category=${category}&` : ''}page=${page - 1}`}
                class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50"
              >
                ← Previous
              </a>
            )}
            <span class="text-sm text-gray-400">
              Page {page} of {totalPages}
            </span>
            {page < totalPages && (
              <a
                href={`/catalogue?${category ? `category=${category}&` : ''}page=${page + 1}`}
                class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50"
              >
                Next →
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</Marketing>
