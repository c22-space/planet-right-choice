{
  "manifest_version": 3,
  "name": "Better Cart",
  "version": "0.1.0",
  "description": "See the carbon footprint of what you buy. Shop greener.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png"
    }
  },
  "permissions": ["storage", "alarms", "webNavigation", "tabs"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.de/*",
    "https://api.bettercart.earth/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["wasm/fp-parser.wasm"],
      "matches": ["<all_urls>"]
    }
  ]
}
